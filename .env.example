# Copy this file to `.env` (same folder) and fill in the two required values.
# `.env` is read automatically by `docker compose up`.

# ---- Required --------------------------------------------------------

# Where your photos live on this machine.
#
# === Single-drive setup (most users) =================================
# Set ONE path. Both services bind-mount it at /photos (read-only)
# inside the containers — so in the gallery's Directory field you type
# `/photos/2024-spring-roll-01` regardless of what the host path is.
#
# Examples:
#   macOS internal:  /Users/you/Pictures
#   macOS drive:     /Volumes/MyPhotoDrive
#   Windows:         C:\Users\You\Pictures   (or D:\Photos for a drive)
#   Linux:           /mnt/photos
PHOTO_LIBRARY=

# === Multi-drive setup (optional) ====================================
# If you want fineshyt to see several drives at once, list them here
# colon-separated. `make compose-init` reads this and generates a
# docker-compose.override.yml that mounts each drive at its REAL host
# path inside the container. So in the gallery you type the actual
# path like `/Volumes/Drive1/Wedding-2024` — and the gallery shows
# each drive as a clickable chip automatically.
#
# Leave blank if you only have one drive. If you set this, you can
# leave PHOTO_LIBRARY blank — `make compose-init` fills it in from
# the first entry below.
#
# Examples:
#   macOS:    /Volumes/Drive1:/Volumes/Drive2:/Users/you/Pictures
#   Linux:    /mnt/drive-a:/mnt/drive-b
# (Multi-drive on Windows is awkward because of drive letters; for
#  Windows users with multiple drives, run several copies of
#  fineshyt or stick to one drive at a time.)
PHOTO_LIBRARIES=

# Don't wrap any path in quotes, even if it has spaces. Don't unplug
# a drive while fineshyt is running — the bind-mount goes stale and
# you'll need to restart the containers.

# Random string used to sign session cookies. Generate one with:
#   openssl rand -base64 48
# (PowerShell on Windows: [Convert]::ToBase64String((1..48 | ForEach-Object {Get-Random -Max 256})) )
SECRET_KEY_BASE=

# ---- Optional --------------------------------------------------------

# Where the converted JPEGs and gallery's served images live. Leave unset to
# use a Docker-managed named volume (opaque to your file manager but zero
# config). Set to any host path to bind-mount instead — useful if you want
# to back up the cache or browse it directly.
#   Example: UPLOADS_DIR=./data/uploads      (relative to the repo)
#   Example: UPLOADS_DIR=/Users/you/fineshyt-cache
UPLOADS_DIR=

# Hostname the orchestrator generates URLs for. Leave as localhost unless
# you're exposing fineshyt to a real network.
PHX_HOST=localhost

# LLM the AI worker calls for the curation pass. Default is a local Ollama
# running on the host with `llava` pulled. To use Claude or another OpenAI-
# compatible endpoint, swap LLM_BASE_URL / LLM_API_KEY / LLM_MODEL.
LLM_BASE_URL=http://host.docker.internal:11434/v1/
LLM_API_KEY=ollama
LLM_MODEL=llava
