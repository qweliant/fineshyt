# Copy this file to `.env` (same folder) and fill in the two required values.
# `.env` is read automatically by `docker compose up`.

# ---- Required --------------------------------------------------------

# Where your photos live on this machine. Both services bind-mount this
# directory at /photos (read-only) inside the containers — so when you point
# fineshyt at a folder in the gallery UI, you'll type something like
# `/photos/2024-spring-roll-01` regardless of what the host path is.
#
# macOS/Linux example: /Users/you/Pictures
# Windows example:     C:\Users\You\Pictures
PHOTO_LIBRARY=

# Random string used to sign session cookies. Generate one with:
#   openssl rand -base64 48
# (PowerShell on Windows: [Convert]::ToBase64String((1..48 | ForEach-Object {Get-Random -Max 256})) )
SECRET_KEY_BASE=

# ---- Optional --------------------------------------------------------

# Hostname the orchestrator generates URLs for. Leave as localhost unless
# you're exposing fineshyt to a real network.
PHX_HOST=localhost

# LLM the AI worker calls for the curation pass. Default is a local Ollama
# running on the host with `llava` pulled. To use Claude or another OpenAI-
# compatible endpoint, swap LLM_BASE_URL / LLM_API_KEY / LLM_MODEL.
LLM_BASE_URL=http://host.docker.internal:11434/v1/
LLM_API_KEY=ollama
LLM_MODEL=llava
