# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Ignore package tarball (built via "mix hex.build").
orchestrator-*.tar

# Ignore assets that are produced by build tools.
/priv/static/assets/

# Ignore digested assets cache.
/priv/static/cache_manifest.json

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/assets/node_modules/

# Uploaded and processed photos — never commit these to the repo
/priv/static/uploads/*.jpg
/priv/static/uploads/*.jpeg
/priv/static/uploads/*.png
/priv/static/uploads/*.gif
/priv/static/uploads/*.webp
/priv/static/uploads/*.heic
/priv/static/uploads/*.heif
/priv/static/uploads/*.tif
/priv/static/uploads/*.tiff
/priv/static/uploads/*.bmp
# RAW formats
/priv/static/uploads/*.raw
/priv/static/uploads/*.arw
/priv/static/uploads/*.cr2
/priv/static/uploads/*.cr3
/priv/static/uploads/*.nef
/priv/static/uploads/*.orf
/priv/static/uploads/*.raf
/priv/static/uploads/*.dng
/priv/static/uploads/*.rw2
/priv/static/uploads/*.pef
/priv/static/uploads/*.srw

